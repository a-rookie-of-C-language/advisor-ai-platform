# Local development configuration example
# Copy this file to application-local.yml and fill in your actual values

spring:
  mvc:
    async:
      request-timeout: 600000
  datasource:
    username: your_db_username
    password: your_db_password

advisor:
  jwt:
    secret: Y25FZHVDcXV0QWR2aXNvckFpUGxhdGZvcm1Bcm9va2llb2ZjbGFuZ3VhZ2U=
  internal:
    token: arookieofc
  memory:
    api-token: arookieofc
    vector-store: pgvector
  embedding:
    model: bge-m3
    dimension: 1024
  ollama:
    base-url: http://localhost:11434
  agent:
    base-url: http://127.0.0.1:8001
    api-token: arookieofc
    timeout-ms: 600000
    debug-stream: false
