            <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Extract access_token" enabled="true">
              <stringProp name="JSONPostProcessor.referenceNames">access_token</stringProp>
              <stringProp name="JSONPostProcessor.jsonPathExprs">$.data.token</stringProp>
              <stringProp name="JSONPostProcessor.match_numbers">1</stringProp>
              <stringProp name="JSONPostProcessor.defaultValues">NA</stringProp>
              <boolProp name="JSONPostProcessor.compute_concat">false</boolProp>
            </JSONPostProcessor>
            <hashTree/>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Extract user_id from jwt" enabled="true">
              <stringProp name="cacheKey">memory-userid-extractor</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="script">import java.util.Base64
def token = vars.get("access_token")
if (token == null || token == "NA") {
  prev.setSuccessful(false)
  prev.setResponseMessage("missing access_token")
  return
}
def parts = token.split("\\.")
if (parts.length &lt; 2) {
  prev.setSuccessful(false)
  prev.setResponseMessage("invalid jwt format")
  return
}
def payload = parts[1].replace('-', '+').replace('_', '/')
while ((payload.length() % 4) != 0) {
  payload += "="
}
def json = new String(Base64.decoder.decode(payload), "UTF-8")
def matcher = (json =~ /"userId"\s*:\s*(\d+)/)
if (!matcher.find()) {
  prev.setSuccessful(false)
  prev.setResponseMessage("userId not found in jwt")
  return
}
vars.put("user_id", matcher.group(1))</stringProp>
            </JSR223PostProcessor>
            <hashTree/>
          </hashTree>
        </hashTree>

