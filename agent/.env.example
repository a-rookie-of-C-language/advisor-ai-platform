# PostgreSQL DSN
DATABASE_URL=postgresql://your_user:your_password@localhost:5432/postgres

# Embedding/OCR config
OLLAMA_BASE_URL=http://localhost:11434

# Runtime mode: indexer | api
AGENT_MODE=indexer

# API mode config
AGENT_API_HOST=127.0.0.1
AGENT_API_PORT=8001

# LLM provider config (preferred)
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2
OPENAI_TIMEOUT_SEC=60

# LLM provider config (legacy compatible)
api_key=
base_url=
model_id=
temperature=0.2
timeout=60

# Memory API config
MEMORY_API_BASE_URL=http://localhost:8080
# required when MEMORY_API_BASE_URL is set
MEMORY_API_TOKEN=arookieofc
