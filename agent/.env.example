# PostgreSQL DSN
DATABASE_URL=postgresql://your_user:your_password@localhost:5432/postgres

# Embedding/OCR config
OLLAMA_BASE_URL=http://localhost:11434

# Runtime mode: all | api | indexer
AGENT_MODE=all

# API mode config
AGENT_API_HOST=127.0.0.1
AGENT_API_PORT=8001
# Optional direct-access protection for /chat/stream.
# If set, request must carry Authorization: Bearer <token> or X-Agent-Token.
AGENT_API_TOKEN=arookieofc

# LLM provider config (preferred)
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2
OPENAI_TIMEOUT_SEC=60

# Tool runtime controls
# Master switch for tool use in chat stream
ENABLE_TOOL_USE=true
# Comma-separated tool whitelist. Empty means all registered tools are enabled.
# Recommended in production: rag_search
ENABLED_TOOLS=rag_search
# Memory API config
MEMORY_API_BASE_URL=http://localhost:8080
# required when MEMORY_API_BASE_URL is set
MEMORY_API_TOKEN=arookieofc


MEMORY_API_TIMEOUT_SEC=30
MEMORY_API_MAX_RETRIES=2
MEMORY_API_RETRY_BACKOFF_SEC=0.3


# Stream debug log switch
DEBUG_STREAM=false
